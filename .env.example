# FORGE Configuration
# Copy this to .env and fill in your API keys

# ── LLM API Keys (at least one required) ──
FORGE_ANTHROPIC_API_KEY=sk-ant-...
FORGE_OPENAI_API_KEY=
FORGE_GOOGLE_API_KEY=

# ── System Settings ──
FORGE_DEBUG=true
FORGE_MAX_PARALLEL_AGENTS=5
FORGE_MIN_REVIEW_SCORE=7.0
FORGE_MAX_FIX_ATTEMPTS=3
FORGE_AGENT_TIMEOUT_SECONDS=300

# ── Model Defaults ──
# Options: claude-opus-4-20250514, claude-sonnet-4-20250514, claude-haiku-4-5-20251001
#          gpt-4o, gpt-4o-mini, o1
#          gemini/gemini-2.5-pro, gemini/gemini-2.5-flash
FORGE_DEFAULT_ARCHITECT_MODEL=claude-opus-4-20250514
FORGE_DEFAULT_BUILDER_MODEL=claude-sonnet-4-20250514
FORGE_DEFAULT_REVIEWER_MODEL=claude-opus-4-20250514

# ── Infrastructure ──
FORGE_DATABASE_URL=sqlite+aiosqlite:///./forge.db
FORGE_REDIS_URL=redis://localhost:6379/0
FORGE_WORKSPACE_DIR=~/.forge/workspaces
